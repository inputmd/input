PORT=8787

# Secret for signing session tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# If not set, a random ephemeral secret is used (sessions won't survive server restarts).
SESSION_SECRET=

# GitHub App settings
GITHUB_APP_ID=123456
GITHUB_APP_SLUG=your-github-app-slug

# Provide exactly one of these:
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/private-key.pem

