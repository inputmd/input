#!/usr/bin/env node
'use strict';

try {
  const { runShopt } = require('../lib/input-shopt.cjs');
  process.exitCode = runShopt(process.argv.slice(2), {
    stderr: process.stderr,
    stdout: process.stdout,
  });
} catch (err) {
  process.stderr.write(`shopt: ${err instanceof Error ? err.stack ?? err.message : String(err)}\n`);
  process.exitCode = 1;
}
