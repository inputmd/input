#!/usr/bin/env node
'use strict';

try {
  const { runWc } = require('../lib/input-wc.cjs');
  process.exitCode = runWc(process.argv.slice(2), {
    stderr: process.stderr,
    stdout: process.stdout,
  });
} catch (err) {
  process.stderr.write(`wc: ${err instanceof Error ? err.stack ?? err.message : String(err)}\n`);
  process.exitCode = 1;
}
