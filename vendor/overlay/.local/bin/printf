#!/usr/bin/env node
'use strict';

try {
  const { runPrintf } = require('../lib/input-printf.cjs');
  process.exitCode = runPrintf(process.argv.slice(2), {
    stderr: process.stderr,
    stdout: process.stdout,
  });
} catch (err) {
  process.stderr.write(`printf: ${err instanceof Error ? err.stack ?? err.message : String(err)}\n`);
  process.exitCode = 1;
}
