#!/usr/bin/env node
'use strict';

try {
  const { runFind } = require('../lib/input-file-search.cjs');
  process.exitCode = runFind(process.argv.slice(2), {
    stderr: process.stderr,
    stdout: process.stdout,
  });
} catch (err) {
  process.stderr.write(`find: ${err instanceof Error ? err.stack ?? err.message : String(err)}\n`);
  process.exitCode = 1;
}
