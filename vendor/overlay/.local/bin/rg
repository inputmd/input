#!/usr/bin/env node
'use strict';

try {
  const { runRg } = require('../lib/input-file-search.cjs');
  process.exitCode = runRg(process.argv.slice(2), {
    stderr: process.stderr,
    stdout: process.stdout,
  });
} catch (err) {
  process.stderr.write(`rg: ${err instanceof Error ? err.stack ?? err.message : String(err)}\n`);
  process.exitCode = 1;
}
