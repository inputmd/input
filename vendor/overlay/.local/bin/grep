#!/usr/bin/env node
'use strict';

try {
  const { runGrep } = require('../lib/input-file-search.cjs');
  process.exitCode = runGrep(process.argv.slice(2), {
    stderr: process.stderr,
    stdout: process.stdout,
  });
} catch (err) {
  process.stderr.write(`grep: ${err instanceof Error ? err.stack ?? err.message : String(err)}\n`);
  process.exitCode = 1;
}
